<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Year_Cannot_Be_In_Future</fullName>
    <active>true</active>
    <errorConditionFormula>Year__c  &gt; YEAR(TODAY()) + 1</errorConditionFormula>
    <errorMessage>Year cannot be in the future</errorMessage>
</ValidationRule>
